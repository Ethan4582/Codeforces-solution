        }
        // get the indegree
        vector<int>indegre(V,0);

        for(int i =0 ;i<V; i++){
            for(auto it: adj[i]){
                indegre[it]++;
            }
        }
        // put in queue
        queue<int>q; 
        for(int i =0; i<V; i++){
            if(indegre[i]==0){
                q.push(i);
            }
        }
        vector<int>ans;
        while(!q.empty()){
            int node=q.front(); 
            q.pop(); 
            ans.push_back(node);
