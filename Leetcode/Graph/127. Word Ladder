class Solution {
public:
    int ladderLength(string B, string E, vector<string>& L) {
        queue<pair<string ,int>>q; 
        q.push({B, 1});
        // check if the word exist in 0(1) 
        unordered_set<string> st(L.begin(), L.end());
        while(!q.empty()){
            string word= q.front().first; 
             int  cnt= q.front().second; 
            q.pop();
            if(word==E) return cnt;
             for(int i =0 ; i<word.size(); i++){
                char org= word[i];
                  for(char ch ='a' ; ch<='z' ; ch++){
                word[i]=ch;
                if(st.find(word)!=st.end()){
                    st.erase(word);
                    q.push({word, cnt+1});
                }
            }
             word[i]=org; // restoring the org word 
             }

          
        } 
        return 0;
    }
};


