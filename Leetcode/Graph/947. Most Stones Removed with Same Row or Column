class Solution {
private: 
void dfs(vector<vector<int>> &G ,int i , vector<int>& vis){
    vis[i]=1; 
    for(auto it: G[i]){
        if(vis[it]) continue; 
        dfs(G , it , vis);
    }
}
int getcomp(vector<vector<int>> & G){
    vector<int>vis(G.size(), 0); 
    int cnt=0;
    for(int i =0; i<G.size(); i++){
        if(!vis[i]){
            dfs(G , i , vis); 
            cnt++;
        }
    }
    return cnt;
}
public:
    int removeStones(vector<vector<int>>& stones) {
        int N= stones.size(); 
        vector<vector<int>> G(N);
        for(int i =0; i <N; i++){
            for(int j =0 ; j<N; j++){
                if(stones[i][0]==stones[j][0] ||  stones[i][1]==stones[j][1]){ // check the same row or column
                 G[i].push_back(j); 
                 G[j].push_back(i);
                }
            }
        }
        return stones.size()-getcomp(G);
    }
};



