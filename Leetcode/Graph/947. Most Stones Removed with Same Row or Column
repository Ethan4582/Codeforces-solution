------------------------DSU-----------------------------------------

TC- ~ O(N²)
SC-0(N)

class DSU {
    public: 
    vector<int> parent, size;

    DSU(int n){
        parent.resize(n); size.resize(n+1 , 0); 
        for(int i =0; i<n; i++){
            parent[i]=i;
        }
    }

    int find(int n){
        if(n!=parent[n]){
            parent[n]= find(parent[n]);
        }
        return parent[n];
    }

    void  unite(int x , int y){
        int pu=find(x); int pv= find(y); 
        if(pu== pv) return ; 
        if(size[pu]<size[pv]){
            parent[pu]=pv;
            size[pv]+=size[pu];
        }else{
             parent[pv]=pu;
            size[pu]+=size[pv];
        }

    }
};
class Solution {
public:
    int removeStones(vector<vector<int>>& stones) {
        int N= stones.size(); 
        DSU dsu(N);
        for(int i =0; i <N; i++){
            for(int j =0 ; j<N; j++){
                if(stones[i][0]==stones[j][0] ||  stones[i][1]==stones[j][1]){ // check the same row or column
                dsu.unite(i, j);
                }
            }
        }

        int conn=0; 
        for(int i =0; i<N; i++){
            if(dsu.find(i)==i){
                conn++;
            }
        }
        return stones.size()-conn;
    }
};



