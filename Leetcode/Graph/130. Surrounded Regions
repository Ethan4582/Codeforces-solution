class Solution {
// mark all the inside 0  -> x except the bounadry and the dignoal does not count 
    int dirs[4][2] = {{1,0},{0,1},{-1,0},{0,-1}};

private:

    void dfs(int i, int j, vector<vector<char>>& grid){

        if(i < 0 || j < 0 || i >= grid.size() || j >= grid[0].size()
           || grid[i][j] != 'O'){
            return;
        }

        grid[i][j] = 'T';

        for(auto &[dx, dy] : dirs){
            dfs(i + dx, j + dy, grid);
        }
    }

public:

    void solve(vector<vector<char>>& grid) {

        int m = grid.size();
        int n = grid[0].size();

        // left + right boundary
        for(int i = 0; i < m; i++){

            if(grid[i][0] == 'O')
                dfs(i, 0, grid);

            if(grid[i][n-1] == 'O')
                dfs(i, n-1, grid);
        }

        // top + bottom boundary
        for(int j = 0; j < n; j++){

            if(grid[0][j] == 'O')
                dfs(0, j, grid);

            if(grid[m-1][j] == 'O')
                dfs(m-1, j, grid);
        }

        // convert
        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){

                if(grid[i][j] == 'O')
                    grid[i][j] = 'X';

                else if(grid[i][j] == 'T')
                    grid[i][j] = 'O';
            }
        }
    }
};