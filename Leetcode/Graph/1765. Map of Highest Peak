class Solution {
    int m, n;

    vector<pair<int,int>> dir = {
        {1,0},{0,1},{-1,0},{0,-1}
    };

    void dfs(vector<vector<int>>& height, int x, int y, int val){

        // out of bounds
        if(x < 0 || y < 0 || x >= m || y >= n)
            return;

        // already found better height
        if(height[x][y] <= val)
            return;

        height[x][y] = val;

        for(auto &[dx, dy] : dir){
            dfs(height, x + dx, y + dy, val + 1);
        }
    }

public:
    vector<vector<int>> highestPeak(vector<vector<int>>& isWater) {

        m = isWater.size();
        n = isWater[0].size();

        vector<vector<int>> height(m, vector<int>(n, INT_MAX));

        // start DFS from every water cell
        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){

                if(isWater[i][j] == 1){

                    height[i][j] = 0;

                    for(auto &[dx, dy] : dir){
                        dfs(height, i + dx, j + dy, 1);
                    }
                }
            }
        }

        return height;
    }
};