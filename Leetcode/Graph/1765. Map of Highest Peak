int dir[4][2]={{1 ,0},{0 ,1}, {-1, 0}, {0 , -1}};
class Solution {
public:
    vector<vector<int>> highestPeak(vector<vector<int>>& grid) {
            int m= grid.size(), n=grid[0].size(); 
         vector<vector<int>> vis(m ,vector<int>(n , 0));
         vector<vector<int>> dis(m ,vector<int>(n , 0));
         queue<pair<pair<int, int>, int>> q; 
          for(int i =0 ; i<m; i++){
            for(int j =0; j<n; j++){
                if(grid[i][j]==1){
                    q.push({{i , j},0}); // i have to start with 1 as its land cell
                    vis[i][j]=1;
                } 
            }
          }

// If isWater[i][j] == 0, cell (i, j) is a land cell.
// If isWater[i][j] == 1, cell (i, j) is a water cell.
          while(!q.empty()){
            int x=q.front().first.first , y=q.front().first.second ,steps=q.front().second;
            q.pop(); 
            dis[x][y]=steps;
            for(auto & it: dir){
                  int xi= x+it[0]; int yi= y+it[1];
                  if(xi>=0 && yi>=0 && xi<m && yi<n && !vis[xi][yi] ){
                     q.push({{xi , yi},steps+1});
                     vis[xi][yi]=1;
                  }
            } 
          }
          return dis;
    }
};




