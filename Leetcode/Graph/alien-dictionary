There is a new alien language that uses the English alphabet. However, the order among the letters is unknown to you.

You are given a list of strings words from the alien language's dictionary, where the strings in words are sorted lexicographically by the rules of this new language.

Return a string of the unique letters in the new alien language sorted in lexicographically increasing order by the new language's rules. If there is no solution, return "". If there are multiple solutions, return any of them.

A string s is lexicographically smaller than a string t if at the first letter where they differ, the letter in s comes before the letter in t in the alien language. If the first min(s.length, t.length) letters are the same, then s is smaller if and only if s.length < t.length.

 Example 1:

Input: words = ["wrt","wrf","er","ett","rftt"]
Output: "wertf"
Example 2:

Input: words = ["z","x"]
Output: "zx"
Example 3:

Input: words = ["z","x","z"]
Output: ""
Explanation: The order is invalid, so return "".

       
Time Complexity: O(N*len)+O(K+E), 

Space Complexity: O(K) + O(K)+O(K)+O(K) ~ O(4K)

class Solution {
private:
    vector<int> topoSort(int K, vector<vector<int>>& adj){
        vector<int> ans;
        queue<int> q;
        vector<int> indegree(K, 0);
        // calculate indegree
        for(int i = 0; i < K; i++){
            for(auto it : adj[i]){
                indegree[it]++;
            }
        }
        // pushing all indegree 0 nodes
        for(int i = 0; i < K i++){

            if(indegree[i] == 0){
                q.push(i);
            }
        }

        while(!q.empty()){
            int node = q.front();
            q.pop();
            ans.push_back(node);
            for(auto it : adj[node]){
                indegree[it]--;
                if(indegree[it] == 0){
                    q.push(it);
                }
            }
        }
        return ans;
    }

public:

    string findOrder(string dict[], int N, int K){
        vector<vector<int>> adj(K);
        // build graph
        for(int i = 0; i < N-1; i++){
            string ch1 = dict[i];
            string ch2 = dict[i+1];

            int len = min(ch1.length(), ch2.length());
            // first different character gives ordering
            for(int ptr = 0; ptr < len; ptr++){
                if(ch1[ptr] != ch2[ptr]){
                    adj[ch1[ptr]-'a'].push_back(ch2[ptr]-'a');
                    break;
                }
            }
        }

        vector<int> topo = topoSort(K, adj);
        string ans = "";
        for(int i = 0; i < topo.size(); i++){
            ans += char(topo[i] + 'a');
        }
        return ans;
    }
};
