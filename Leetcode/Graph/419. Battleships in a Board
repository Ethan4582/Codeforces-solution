	class Solution {
public:
    int countBattleships(vector<vector<char>>& A) {
        int M= A.size(), N=A[0].size(), ans=0; 
        for(int i =0; i < M; i++){
            for(int j =0; j<N; j++){
                if(A[i][j]=='X'){
                    // check for boaudnru conditon like 
                    if((i ==0 || A[i-1][j]=='.') && (j ==0 || A[i][j-1]=='.')){
                    ans++;
                }
                }
            }
        }
        return ans;
    }
};


