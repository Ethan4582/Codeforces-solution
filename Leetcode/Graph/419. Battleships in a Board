Approach	Time	Space
DFS	O(NM)	O(NM)

class Solution {
 int dirs[4][2] = {{0,1},{0,-1},{1,0},{-1,0}};
private:
void dfs(int i, int j, vector<vector<char>>& A, vector<vector<int>>& vis){
     vis[i][j] = 1;
        int m = A.size(), n = A[0].size();
       for(auto & it: dirs){
        int x= i+it[0];
        int y= j+it[1];
        if(x>=0 && y>=0 && x<m && y<n && A[x][y]=='X' && !vis[x][y]){
             dfs(x , y , A ,vis);
        }
       }
}

public:
    int countBattleships(vector<vector<char>>& A) {
        int ans=0; 
           int m = A.size(), n = A[0].size();
        vector<vector<int>> vis(m , vector<int>(n , 0)); 
        for(int i =0 ; i<m ; i++){
            for(int j =0 ; j<n; j++){
                if(A[i][j]=='X' && !vis[i][j]){
                    ans++;
                    dfs(i , j  , A ,vis);
                }
            }
        }
        return ans;
    }
};

