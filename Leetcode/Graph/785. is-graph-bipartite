2 adjacent node has to be unique color  [ even length size]

-> if the length is odd then then it can never be bipartite 
 

 Time Complexity
O(V + E)
Space Complexity
O(V)

class Solution {
bool dfs(int node , int col ,vector<vector<int>>& graph ,  vector<int>& vis  ){
    vis[node]=col; 
    for(auto it: graph[node]){
         // if not visited 
         if(vis[it]==-1){
            if(!dfs(it ,!col ,graph , vis)) return false;
         }else if(vis[it]==col){
            return false;
         }
    }
    // everyhting is fine 
    return true;
}
public:
    bool isBipartite(vector<vector<int>>& graph) {
        vector<int>vis(graph.size(), -1); 
        for(int i =0 ; i<graph.size(); i++){
            if(vis[i]==-1){
                if(dfs(i ,0 , graph ,vis) == false){
                    return false;
                }
            }
        }
        return true;
    }
};