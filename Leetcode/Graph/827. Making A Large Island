class Solution {
     int dir[4][2] = {
        {1,0},
        {0,1},
        {-1,0},
        {0,-1}
    };

private: 
int dfs(vector<vector<int>>& grid , int & k , int & m , vector<vector<int>>& vis){
  
    int cnt=1;
    if(k>=grid.size() || m>=grid.size() || k<0 || m<0 ||  grid[k][m] == 0 || vis[k][m]==1){
        return 0;
    }
      vis[k][m]=1;

    for(auto it:dir){
       int x = k + it[0];
            int y = m + it[1];
            cnt += dfs(grid, x, y, vis);
    }
    return cnt;
};
public:
    int largestIsland(vector<vector<int>>& grid) {
        int n= grid.size(); 
        bool haszero= false; 
        int ans=0;
        for(int i =0; i<n; i++){
            for(int j=0; j<n;j++){

                if(grid[i][j]==0){
                    haszero= true;
                    grid[i][j]=1;
                    vector<vector<int>> vis(n,vector<int>(n, 0));
                    int curr = 0;
                    for(int k =0; k<n;k++){
                        for(int m=0; m<n; m++){
                            if(grid[k][m]==1 && !vis[k][m]){
                                curr= max(curr , dfs(grid , k , m , vis) );
                            }
                        }
                    }

                    ans= max(ans , curr);
                    grid[i][j] = 0;
                }

           
            }
              
        }
        // all of them are 1
         if(!haszero) {
            return n * n;
        }
        return ans;
    }
};








--------------------------DSU-------------------------------------

intuion - dynamic graph it is chnaging thenm union by size , tp avoid duplicate count just use findUparent of same no need to count as this is already be computed same answer , we need single unit number to use DSU to track as current their in index  , union by size just gives use the size of the components 



class DSU {
public:
    vector<int> rank, parent, size;

    DSU(int n) {
        rank.resize(n + 1, 0);
        parent.resize(n + 1);
        size.resize(n + 1);
        for (int i = 0; i <= n; i++) {
            parent[i] = i;
            size[i] = 1;
        }
    }
    
    int findUPar(int node) {
        if (node == parent[node])
            return node;
        return parent[node] = findUPar(parent[node]);
    }
    
    void unionByRank(int u, int v) {
        int ulp_u = findUPar(u);
        int ulp_v = findUPar(v);
        if (ulp_u == ulp_v) return;
        if (rank[ulp_u] < rank[ulp_v]) {
            parent[ulp_u] = ulp_v;
        }
        else if (rank[ulp_v] < rank[ulp_u]) {
            parent[ulp_v] = ulp_u;
        }
        else {
            parent[ulp_v] = ulp_u;
            rank[ulp_u]++;
        }
    }
    
    void unionBySize(int u, int v) {
        int ulp_u = findUPar(u);
        int ulp_v = findUPar(v);
        if (ulp_u == ulp_v) return;
        if (size[ulp_u] < size[ulp_v]) {
            parent[ulp_u] = ulp_v;
            size[ulp_v] += size[ulp_u];
        }
        else {
            parent[ulp_v] = ulp_u;
            size[ulp_u] += size[ulp_v];
        }
    }
};

class Solution {
     int dir[4][2] = { {1,0}, {0,1}, {-1,0}, {0,-1} };
private: 
bool valid(int &i, int &j, int &n){
     if(i < 0 || i >= n || j < 0 || j >= n) return false;
        return true;
}
void convert(vector<vector<int>>& grid ,DSU & dsu , int& n){
     // convert to connected component 
     for(int i =0 ; i<n; i++){
        for(int j =0; j<n; j++){
            if(grid[i][j]==0) continue; 

            for(auto &it: dir ){
                int x= it[0]+i; int y= it[1]+j;
                // check if valid 
                if(valid(x,y , n) && grid[x][y]==1){
                    int currnode=i*n+j; 
                    int adjnode=x*n+y; 
                    dsu.unionBySize(currnode , adjnode);
                }
            }
        }
     }
}
public:
    int largestIsland(vector<vector<int>>& grid) {
         int n = grid.size();
        DSU dsu(n*n);
        // converting all the current post into connected component 
        convert(grid ,dsu, n);
        int ans=0;

        // tranver and flip and calculate the answer

        for(int i =0; i<n; i++){
            for(int j =0;j<n; j++){
                 if (grid[i][j] == 1) continue;
                  set<int> components;
                for(auto &it: dir ){
                    int x= it[0]+i; int y= it[1]+j;
                  
                    if (valid(x, y, n) && grid[x][y] == 1) {
                        // get all the ultiate parent  to whcih current node is  connect to different component 
                        int nodeNumber = x * n + y;
                        components.insert(dsu.findUPar(nodeNumber));
                    }   
                }

                int sizeSum = 0;
                for(auto comp: components){
                    // get the size fo total all connected components
                    sizeSum += dsu.size[comp];
                }     
                // count itself 
                 ans = max(ans, sizeSum + 1);  
            }     
        }

           // Edge case  if to avoid duplicat 
           //ex-       x  1           -> we might count this 2 times
        ///            x  x  x x
        for (int cellNo = 0; cellNo < n * n; cellNo++) {
            
            // Keep the answer updated
            ans = max(ans, dsu.size[dsu.findUPar(cellNo)]);
        }
        
        // Return the answer
        return ans;
        
    }
};