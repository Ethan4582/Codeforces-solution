      //       vector<int> temp;
      //       dfs3(transpose_graph, vis, node, temp);
      //       ans.push_back(temp);
      //    }
      // }

      return ans;
   }
};



class Solution {
private:
    // DFS to find the finish time of each node
    void dfs1(int node, vector<vector<int>>& adj, vector<int>& vis, stack<int>& st) {
        vis[node] = 1;
        for (auto nxt : adj[node]) {
            if (!vis[nxt]) {
                dfs1(nxt, adj, vis, st);
            }
        }
        st.push(node);
    }

    // DFS to find the strongly connected components
    void dfs2(int node, vector<vector<int>>& rev, vector<int>& comp, int id) {
        comp[node] = id;
        for (auto nxt : rev[node]) {
            if (comp[nxt] == -1) {
                dfs2(nxt, rev, comp, id);
            }
        }
    }

public:
   
    vector<string> maxNumOfSubstrings(string s) {
        int n = s.size();

        vector<int> first(26, n);
        vector<int> last(26, -1);

        // store the occurrence 
        for (int i = 0; i < n; i++) {
            int c = s[i] - 'a';
            first[c] = min(first[c], i);
            last[c] = max(last[c], i);
        }

        // graph and transpose graph 
        vector<vector<int>> adj(26);
        vector<vector<int>> rev(26);

        // build the graph to the edge 
        for (int c = 0; c < 26; c++) {
            if (last[c] == -1) continue;

            for (int i = first[c]; i <= last[c]; i++) {
                int nxt = s[i] - 'a';
                // avoid the oneslef edge
                if (nxt == c) continue;
                adj[c].push_back(nxt);
                rev[nxt].push_back(c);
            }
        }

        // ssc algorithm 
        vector<int> vis(26, 0);
        stack<int> st;

        for (int i = 0; i < 26; i++) {
            if (last[i] == -1) continue;

            if (!vis[i]) {
                dfs1(i, adj, vis, st);
            }
        }

        vector<int> comp(26, -1);
        int sccCount = 0;

        while (!st.empty()) {
            int node = st.top();
            st.pop();
            if (comp[node] == -1) {
                dfs2(node, rev, comp, sccCount);
                sccCount++;
            }
        }

        vector<int> outdeg(sccCount, 0);

        vector<int> L(sccCount, n);
        vector<int> R(sccCount, -1);

        // compress the scc graph 
        for (int u = 0; u < 26; u++) {
            if (last[u] == -1) continue;

            L[comp[u]] = min(L[comp[u]], first[u]);
            R[comp[u]] = max(R[comp[u]], last[u]);

            for (auto v : adj[u]) {
                if (comp[u] != comp[v]) { // to skip the indegree 0
                    outdeg[comp[u]]++;
                }
            }
        }

        vector<pair<int, int>> intervals;

        for (int scc = 0; scc < sccCount; scc++) {
            if (outdeg[scc] == 0) {
                intervals.push_back({ L[scc], R[scc] }); // marking the path 
            }
        }

        sort(intervals.begin(), intervals.end(), [](auto& a, auto& b) {
            return a.second < b.second;
        });

        vector<string> ans;

        int end = -1;

        for (auto& [l, r] : intervals) {

            if (l > end) {
                ans.push_back(s.substr(l, r - l + 1));
                end = r; // marking this much is covered 
            }
        }

        return ans;
    }
};
