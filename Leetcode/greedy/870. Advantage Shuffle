Brute force

class Solution {
public:
    vector<int> advantageCount(vector<int>& nums1, vector<int>& nums2) {

        sort(nums1.begin(), nums1.end());

        vector<int> vis(nums1.size(), 0);

        vector<int> ans;

        for(int i = 0; i < nums2.size(); i++) {

            bool found = false;

            for(int j = 0; j < nums1.size(); j++) {

                if(nums1[j] > nums2[i] && !vis[j]) {

                    vis[j] = 1;
                    ans.push_back(nums1[j]);
                    found = true;
                    break;
                }
            }

            if(!found) {

                for(int j = 0; j < nums1.size(); j++) {

                    if(!vis[j]) {

                        vis[j] = 1;
                        ans.push_back(nums1[j]);
                        break;
                    }
                }
            }
        }

        return ans;
    }
};
																								
