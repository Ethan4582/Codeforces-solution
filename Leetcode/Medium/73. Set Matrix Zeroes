


class Solution {
public:
    void setZeroes(vector<vector<int>>& mat) {
        int m = mat[0].size(); 
        int n = mat.size();
        vector<int> xx(m, 0), yy(n, 0); 

        for(int i = 0; i < n; i++) {  
            for(int j = 0; j < m; j++) {  
                if(mat[i][j] == 0) {
                    xx[j] = 1; 
                    yy[i] = 1;
                }
            }
        }

        for(int i = 0; i < n; i++) {  
            for(int j = 0; j < m; j++) {  
                if(xx[j] == 1 || yy[i] == 1) {  
                    mat[i][j] = 0;  // 
                }
            }
        }
    }
};




class Solution {
public:
    void setZeroes(vector<vector<int>>& mat) {
        int m = mat[0].size(); 
        int n = mat.size();
        bool zeroinFirstCol = false;

        for(int i = 0; i < n; i++) {  
            if(mat[i][0] == 0) zeroinFirstCol = true;  
            for(int j = 1; j < m; j++) {
                if(mat[i][j] == 0) {
                    mat[i][0] = 0;  
                    mat[0][j] = 0;  
                }
            }
        }

        for(int i = 1; i < n; i++) {  
            for(int j = 1; j < m; j++) {  
               if(mat[i][0] == 0 || mat[0][j] == 0) {  
                mat[i][j] = 0;
               }
            }
        }

        if (mat[0][0] == 0) {
            for (int j = 1; j < m; j++) {  
                mat[0][j] = 0;
            }
        }

        if (zeroinFirstCol) {
            for (int i = 0; i < n; i++) {  
                mat[i][0] = 0;  
            }
        }
    }
};